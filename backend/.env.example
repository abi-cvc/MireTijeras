GOOGLE_CLIENT_ID=tu_client_id_de_google
GOOGLE_CLIENT_SECRET=tu_client_secret_de_google

# PostgreSQL (Neon)
PGHOST=tu_host_de_neon
PGUSER=tu_usuario
PGPASSWORD=tu_password
PGDATABASE=tu_basededatos
PGPORT=5432

# Admin credentials
# Genera el hash con: node scripts/generateHash.js tu_password
ADMIN_EMAIL=tu_email_admin
ADMIN_PASSWORD_HASH=hash_generado_con_bcrypt

# JWT (usa una cadena larga aleatoria)
JWT_SECRET=cambia_esto_por_una_clave_secreta_larga

# CORS (dominios permitidos, separados por coma)
ALLOWED_ORIGINS=https://tu-frontend.vercel.app,http://localhost:8000

# Puerto del servidor
PORT=3001
